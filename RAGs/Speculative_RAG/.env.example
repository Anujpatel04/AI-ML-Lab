# Copy to repo root .env and set values.
# OpenAI (if not using Azure)
OPENAI_API_KEY=sk-...

# Azure OpenAI (optional; takes precedence when set)
AZURE_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
AZURE_KEY=...
API_VERSION=2025-01-01-preview

# Optional: separate deployments for draft and verifier
# AZURE_DRAFT_DEPLOYMENT=gpt-4o-mini
# AZURE_VERIFIER_DEPLOYMENT=gpt-4o

# Optional RAG tuning
# RAG_TOP_K=5
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=100
# RAG_TEMPERATURE=0.3
# RAG_MAX_TOKENS=1024
