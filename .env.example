# Single .env for the whole repo — no per-project .env files.

# Required for most AI agents
OPENAI_API_KEY=

# Azure OpenAI (optional; RAGs and agents use this when set)
# AZURE_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
# AZURE_KEY=
# API_VERSION=2025-01-01-preview

# Optional - project-specific
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
EXA_API_KEY=
QDRANT_API_KEY=
QDRANT_URL=
OLLAMA_EMBED_MODEL=nomic-embed-text
FIRECRAWL_API_KEY=
DEEPGRAM_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=memory-rag
# Neo4j (Hybrid Graph RAG)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Supabase (e.g. Voice Tutor)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_TABLE=voice_tutor_conversations
